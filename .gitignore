node_modules/
dist/
coverage/
*.log

# Forge runtime state (ephemeral; never committed)
.forge/

# Local AI session context (onboarding artifact; not part of the tool).
# Track ONLY the project-level runner safety policy (settings.json + the
# permissions hook directory); everything else in .claude/ (including
# settings.local.json — local machine config) stays untracked.
.claude/*
!.claude/settings.json
!.claude/hooks
!.claude/hooks/**

# Local-only scratch for pilots / external imports — keep external or private
# project material OUT of this public tool repo. (Note: sandbox-epic/ is a tracked
# sterile ForgeGate test fixture and is intentionally NOT ignored.)
pilot-local/
sandbox-local/
*.private.md

# Repomix — local handoff artifacts (config + exports). Never tracked.
*repomix*
*RepoMix*
